# ─── Primary news source (real-time, free) ───────────────────────────────────
# Get a free key at https://open-platform.theguardian.com/access/
GUARDIAN_API_KEY=your_guardian_api_key_here

# ─── Fallback news source (24h delay on free plan) ───────────────────────────
# Get a free key at https://newsapi.org (100 req/day on developer plan)
NEWSAPI_KEY=your_newsapi_key_here

# ─── Optional ─────────────────────────────────────────────────────────────────
# How often (minutes) the server fetches fresh news.
# Default: 25 min → ~58 Guardian requests/day (free plan is very generous)
# Guardian is tried first; NewsAPI is the fallback if Guardian fails.
NEWS_REFRESH_MINUTES=25
