# ─── Required ────────────────────────────────────────────────────────────────
# Get a free key at https://newsapi.org (100 req/day on developer plan)
NEWSAPI_KEY=your_newsapi_key_here

# ─── Optional ─────────────────────────────────────────────────────────────────
# How often (minutes) the server fetches fresh news from NewsAPI.
# Default: 25 min → ~58 requests/day (well within the 100/day free limit)
# Minimum recommended: 15 min (96 req/day, borderline)
NEWS_REFRESH_MINUTES=25
